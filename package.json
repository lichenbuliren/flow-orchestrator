{
  "name": "state-flow",
  "version": "0.1.0",
  "description": "A high-cohesion, low-coupling flow orchestration engine for multi-step workflows",
  "main": "src/index.ts",
  "sideEffects": false,
  "publishConfig": {
    "main": "./dist/index.js",
    "module": "./dist/index.esm.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.esm.js",
        "require": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "package.json",
    "CHANGELOG.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit -p ./tsconfig.json --pretty true",
    "test": "jest",
    "prepack": "pnpm build"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "react": "^18.0.0",
    "@types/react": "^18.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0"
  },
  "keywords": [
    "state-flow",
    "flow-engine",
    "workflow",
    "state-machine",
    "orchestration",
    "react-native",
    "multi-step"
  ],
  "license": "MIT"
}
